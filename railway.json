{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "mvn -f services/api/pom.xml -DskipTests package"
  },
  "deploy": {
    "startCommand": "java -jar services/api/target/peralta-pos-api-0.1.0.jar",
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
