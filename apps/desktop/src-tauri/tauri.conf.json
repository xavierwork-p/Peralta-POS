{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Peralta POS",
  "version": "0.1.0",
  "identifier": "com.peralta.pos",
  "build": {
    "beforeDevCommand": "powershell -ExecutionPolicy Bypass -File ../../../scripts/dev-web.ps1",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "powershell -ExecutionPolicy Bypass -File ../../../scripts/build-web.ps1",
    "frontendDist": "../../web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Peralta POS",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 680,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "category": "Business",
    "shortDescription": "Sistema de punto de venta empresarial",
    "longDescription": "Peralta POS es un sistema web y escritorio para ventas, inventario, cotizaciones, facturacion y reportes."
  }
}
