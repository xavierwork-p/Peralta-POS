# Backend
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080

# MySQL connection.
# Local MySQL default:
DB_URL=jdbc:mysql://localhost:3306/peralta_pos?createDatabaseIfNotExist=true&serverTimezone=UTC&allowPublicKeyRetrieval=true&useSSL=false
DB_USER=peralta
DB_PASSWORD=peralta123

# Optional remote MySQL example:
# DB_URL=jdbc:mysql://your-host:3306/peralta_pos?serverTimezone=UTC&allowPublicKeyRetrieval=true&useSSL=true
# DB_USER=your-user
# DB_PASSWORD=your-password

# JWT demo secret. Replace in real deployments.
JWT_SECRET=replace-with-a-long-secure-secret

# Allowed origins for browser clients.
# Local default:
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,tauri://localhost
# Production example:
# CORS_ALLOWED_ORIGINS=https://tu-frontend.vercel.app,tauri://localhost

# Railway production profile.
# In Railway set SPRING_PROFILES_ACTIVE=railway.
# Railway MySQL exposes MYSQLHOST, MYSQLPORT, MYSQLUSER, MYSQLPASSWORD and MYSQLDATABASE automatically.

# Render + Aiven production demo profile.
# In Render set SPRING_PROFILES_ACTIVE=render.
# Aiven MySQL example:
# DB_URL=jdbc:mysql://HOST:PORT/defaultdb?sslMode=REQUIRED&serverTimezone=UTC&allowPublicKeyRetrieval=true
# DB_USER=avnadmin
# DB_PASSWORD=your-aiven-password

# Frontend
VITE_API_BASE_URL=http://localhost:8080/api
VITE_CLIENT_CHANNEL=WEB
